# Copy to .env and adjust for local runs.
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Async SQLAlchemy URL (PostgreSQL in production; SQLite supported for dev/tests)
DATABASE_URL=postgresql+asyncpg://test:test@localhost:5432/test_db

OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini

# Pipeline limits
MAX_COST_PER_RUN_USD=5.0
PIPELINE_MAX_CONCURRENCY=3
HTTP_MAX_RESPONSE_BYTES=2000000
MAX_PAGES_PER_COMPANY=6

# Alerting thresholds (mock Slack/email in dev)
ALERT_CONSECUTIVE_FAILURE_THRESHOLD=3
ALERT_AVG_QUALITY_THRESHOLD=0.35
